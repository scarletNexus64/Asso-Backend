                               onchange="updatePricelistZones()"
                               class="w-full px-4 py-2 bg-dark-100 border border-dark-300 text-white rounded-lg focus:ring-2 focus:ring-primary-500">
                    </div>

                    <!-- Map with autocomplete search -->
